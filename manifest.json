{
  "manifest_version": 3,
  "name": "Taiwan Ebookstore Helper",
  "version": "0.4.0",
  "key": "",
  "description": "支援 Readmoo、博客來、Kobo TW：折扣試算、領書額度建議、名單過濾突顯、待購清單備註與標籤。最優價格計算僅供參考，請以書商系統為主。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://readmoo.com/*",
    "https://reader.readmoo.com/*",
    "https://new-read.readmoo.com/*",
    "https://*.books.com.tw/*",
    "https://*.kobo.com/tw/*"
  ],
  "options_page": "management.html",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://readmoo.com/*",
        "https://*.books.com.tw/*",
        "https://*.kobo.com/tw/*"
      ],
      "js": [
        "sites.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://reader.readmoo.com/*"
      ],
      "js": [
        "readmoo_reader_main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://reader.readmoo.com/*"
      ],
      "js": [
        "readmoo_reader.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
